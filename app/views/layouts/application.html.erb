<!DOCTYPE html>
<html class="<%= 'dark-mode' if dark_mode? %>">
  <head>
    <!-- Preload dark mode to prevent flash - must be before any CSS -->
    <script>!function(){var t=localStorage.getItem("theme-preference");if("dark"===t){document.write('<style id="dm-preload">.dark-mode,html.dark-mode,body.dark-mode{background:#24262b!important;background-color:#24262b!important}</style>')}}();</script>
    <title>CUMarket</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="CUHK Campus Marketplace - Buy and sell items within the CUHK community">
    <meta name="theme-color" content="#5b2c83">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= javascript_include_tag 'notification', defer: true %>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="<%= asset_path('icon.svg') %>">
    <link rel="icon" type="image/png" sizes="32x32" href="<%= asset_path('icon.png') %>">
    <link rel="apple-touch-icon" href="<%= asset_path('icon.png') %>">

    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.15.4/css/all.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>

  <body class="<%= 'dark-mode' if dark_mode? %>">
    <%= render "application/flashes" %>
    <%= yield %>
  </body>
</html>