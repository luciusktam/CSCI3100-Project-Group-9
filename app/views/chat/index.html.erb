<div class="app">
  <header class="navbar">
    <div class="navbar-left">
      <%= link_to community_path, class: "nav-community-btn#{' active' if request.path.start_with?('/community')}", aria: { label: "Community" } do %>
        <i class="fas fa-users"></i>
      <% end %>
      <%= link_to root_path, class: "logo" do %>
        CUMarket
      <% end %>
    </div>
    <div class="nav-links">
      <% if user_signed_in? && current_user.admin? %>
        <%= link_to admin_dashboard_path, class: "admin-nav-link#{' active' if request.path.start_with?('/admin')}" do %>
          <i class="fas fa-shield-alt"></i> Admin
        <% end %>
      <% end %>
    </div>
    <div class="right-corner">
      <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle dark mode">
        <i class="fas fa-moon"></i>
        <span>Dark</span>
      </button>
      <% if user_signed_in? %>
        <%= link_to profile_path, class: "session-badge" do %>
          <% if current_user.avatar.attached? %>
            <%= image_tag current_user.avatar, alt: "User icon", class: "session-avatar-image" %>
          <% else %>
            <i class="fas fa-user-circle session-avatar-icon"></i>
          <% end %>
          <%= current_user.username %>
          <% if current_user.admin? %>
            <strong>Admin</strong>
          <% end %>
        <% end %>
        <% active_class = request.path.start_with?("/chat") ? "nav-chat-btn active" : "nav-chat-btn" %>
        <%= link_to chat_path, class: active_class, "aria-label": "Chat" do %>
          <i class="fas fa-comment-dots"></i>
          <span id="chatNavBadge" class="nav-badge" style="display: none;">0</span>
        <% end %>
      <% else %>
        <%= link_to login_path, class: "login-btn" do %>
          <i class="fas fa-sign-in-alt"></i> Login
        <% end %>
      <% end %>
    </div>
  </header>

  <div class="main-chat-layout">
    <div class="chat-sidebar">
      <div class="search-container">
        <input type="text" id="searchUsers" placeholder="Search users or chats">
      </div>

      <div class="user-list" id="userListContainer">
        <% if @chat_users.any? %>
          <% @chat_users.each do |user| %>
            <% conversation = Conversation.find_or_create_between(current_user, user) %>
            <% unread_count = conversation.unread_count_for(current_user) %>
            <%= link_to chat_with_user_path(user), class: "user-item #{'active' if @other_user && @other_user.id == user.id}", data: { user_id: user.id, username: user.username } do %>
              <div class="user-avatar">
                <%= user.username.first.upcase %>
              </div>
              <div class="user-info">
                <div class="user-name">
                  <%= user.username %>
                  <% if unread_count > 0 %>
                    <span class="unread-badge"><%= unread_count %></span>
                  <% end %>
                </div>
                <div class="user-status">
                  <%= conversation.last_message&.content&.truncate(30) || "Click to start chatting" %>
                </div>
              </div>
              <div class="conversation-time">
                <%= time_ago_in_words(conversation.updated_at) %> ago
              </div>
            <% end %>
          <% end %>
        <% else %>
          <div class="empty-user-list">
            <i class="fas fa-comments"></i>
            <p>Find a seller to chat with!</p>
            <small>Click "Chat with seller" on any listing to start a conversation</small>
          </div>
        <% end %>
      </div>
    </div>

    <div class="chat-window" id="chatWindow">
      <div class="chat-placeholder" id="chatPlaceholder" style="<%= @other_user ? 'display: none;' : 'display: flex;' %>">
        <i class="fas fa-comments placeholder-icon"></i>
        <div class="placeholder-text">
          <strong>No conversation selected</strong><br>
          Choose a user to start messaging.
        </div>
      </div>

      <div id="activeChatView" style="<%= @other_user ? 'display: flex;' : 'display: none;' %>; flex-direction: column; height: 100%;">
        <div class="chat-header" id="activeChatHeader">
          <div class="user-avatar" id="activeAvatar">
            <%= @other_user&.username&.first&.upcase || '?' %>
          </div>
          <div class="chat-header-name" id="activeUserName">
            <%= @other_user&.username || '' %>
          </div>
        </div>

        <% if @conversation %>
          <%= turbo_stream_from "conversation_#{@conversation.id}" %>
        <% end %>

        <div class="messages-area" id="messagesArea">
          <% if @messages && @messages.any? %>
            <% @messages.each do |message| %>
              <%= render "messages/message", message: message %>
            <% end %>
          <% else %>
            <div class="empty-chat-note">No messages yet. Start the conversation!</div>
          <% end %>
        </div>
        <div class="chat-input-area">
          <input type="text" id="messageInput" placeholder="Type a message..." autocomplete="off">
          <button class="send-btn" id="sendMessageBtn">
            <i class="fas fa-paper-plane"></i>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Include CSRF token for JavaScript -->
<%= tag.meta name: "csrf-token", content: form_authenticity_token %>

<%= javascript_include_tag 'chat', defer: true %>
