<div class="app">
    <!-- header with login on the upper right corner -->
    <header class="navbar">
        <div class="logo">
            <i class="fas fa-exchange-alt"></i> CUSHMS
        </div>
        <div class="nav-links">
            <%= link_to community_path do %>
                <i class="fas fa-users"></i> Community
            <% end %>
            <%= link_to chat_path do %>
                <i class="fas fa-comment-dots"></i> Chat
            <% end %>
            <%= link_to sell_path do %>
                <i class="fas fa-euro-sign"></i> Sell
            <% end %>
            <%= link_to profile_path do %>
                <i class="fas fa-user-circle"></i> Profile
            <% end %>
        </div>
        <div class="right-corner">
            <%= link_to login_path, class: "login-btn" do %>
                <i class="fas fa-sign-in-alt"></i> Login
            <% end %>
        </div>
    </header>

    <!-- homepage: search + filter function -->
    <div class="search-section">
        <div class="search-row">
            <div class="search-box">
                <i class="fas fa-search"></i>
                <%= text_field_tag :search, params[:search], 
                      placeholder: "Search for an item",
                      id: "search-input" %>
            </div>
            <div class="filter-dropdowns">
                <span class="filter-tag"><i class="fas fa-tag"></i> Category</span>
                <span class="filter-tag"><i class="fas fa-dollar-sign"></i> Price</span>
                <span class="filter-tag"><i class="fas fa-map-pin"></i> Location</span>
            </div>
            <%= button_tag class: "search-btn" do %>
                <i class="fas fa-arrow-right"></i> Search
            <% end %>
        </div>
        <div class="filter-chip" style="display: flex; align-items: center; justify-content: space-between;">
            <h2><i class="fas fa-sliders-h" style="margin-right: 10px; color:#2563eb;"></i> Filters</h2>
            <span class="filter-tag" style="display: inline-flex; align-items: center; gap: 5px; color: #2563eb; cursor: pointer;"> 
                <i class="fas fa-trash-alt"></i> clear all
            </span>
        </div>
    </div>

    <!-- listed items (homepage product grid) -->
    <div class="section-header">
        <h2><i class="fas fa-store-alt" style="margin-right: 10px; color:#2563eb;"></i> Fresh listings</h2>
        <%= link_to listings_path do %>
            view all <i class="fas fa-chevron-right" style="font-size:0.8rem;"></i>
        <% end %>
    </div>

    <div class="product-grid">
        <% if @fresh_listings.present? %>
            <% @fresh_listings.each do |listing| %>
                <%= link_to listing_path(listing), class: "product-card" do %>
                    <!-- You'll add image here later with ActiveStorage -->
                    <div class="product-card-content">
                        <h3><%= listing.title %></h3>
                        <p class="price"><%= number_to_currency(listing.price) %></p>
                        <p class="location"><%= listing.location %></p>
                    </div>
                <% end %>
            <% end %>
        <% else %>
            <p class="no-listings">No listings yet. Be the first to sell something!</p>
        <% end %>
    </div>
</div>