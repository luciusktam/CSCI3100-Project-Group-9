<div class="app">
    <!-- header with login on the upper right corner -->
    <%= render "home/header" %>

    <!-- homepage: search + filter function -->
    <div class="search-section">
        <div class="search-row">
            <div class="search-box">
                <i class="fas fa-search"></i>
                <%= text_field_tag :search, params[:search], 
                      placeholder: "Search for an item",
                      id: "search-input" %>
            </div>
            <div class="filter-dropdowns">
                <span class="filter-tag"><i class="fas fa-tag"></i> Category</span>
                <span class="filter-tag"><i class="fas fa-dollar-sign"></i> Price</span>
                <span class="filter-tag"><i class="fas fa-map-pin"></i> Location</span>
            </div>
            <%= button_tag class: "search-btn" do %>
                <i class="fas fa-arrow-right"></i> Search
            <% end %>
        </div>
        <div class="filter-chip filter-chip-row">
            <h2><i class="fas fa-sliders-h filter-title-icon"></i> Filters</h2>
            <span class="filter-tag filter-clear"> 
                <i class="fas fa-trash-alt"></i> clear all
            </span>
        </div>
    </div>

    <!-- listed items (homepage product grid) -->
    <div class="section-header">
        <h2>Fresh listings</h2>
        <%= link_to listings_path do %>
            view all <i class="fas fa-chevron-right section-link-icon"></i>
        <% end %>
    </div>

    <div class="product-grid">
        <% if @fresh_listings.present? %>
            <% @fresh_listings.each do |listing| %>
                <%= link_to listing_path(listing), class: "product-card" do %>
                    <!-- You'll add image here later with ActiveStorage -->
                    <div class="product-card-content">
                        <h3><%= listing.title %></h3>
                        <p class="price"><%= number_to_currency(listing.price) %></p>
                        <p class="location"><%= listing.location %></p>
                    </div>
                <% end %>
            <% end %>
        <% else %>
            <p class="no-listings">No listings yet. Be the first to sell something!</p>
        <% end %>
    </div>
</div>