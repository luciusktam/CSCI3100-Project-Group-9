<div class="app">
   <header class="navbar">
        <%= link_to root_path, class: "logo" do %>
            CUMarket
        <% end %>
        <div class="nav-links">
            <%= link_to community_path do %>
                <i class="fas fa-users"></i> Community
            <% end %>
            <%= link_to chat_path do %>
                <i class="fas fa-comment-dots"></i> Chat
            <% end %>
            <%= link_to sell_path do %>
                <i class="fas fa-euro-sign"></i> Sell
            <% end %>
            <%= link_to profile_path do %>
                <i class="fas fa-user-circle"></i> Profile
            <% end %>
        </div>
        <div class="right-corner">
            <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle dark mode" aria-pressed="false">
                <i class="fas fa-moon"></i>
                <span>Dark</span>
            </button>
            <% if user_signed_in? %>
                <span class="session-badge">
                    <i class="fas fa-user-check"></i>
                    <%= current_user.username %>
                    <% if current_user.admin? %>
                        <strong>Admin</strong>
                    <% end %>
                </span>
                <%= button_to logout_path, method: :delete, class: "login-btn logout-btn" do %>
                    <i class="fas fa-sign-out-alt"></i> Logout
                <% end %>
            <% else %>
            <%= link_to login_path, class: "login-btn" do %>
                <i class="fas fa-sign-in-alt"></i> Login
            <% end %>
            <% end %>
        </div>
    </header>

  <div class="new-listing-container">
    <div class="form-card">
      <h2 class="form-title">Create a new listing</h2>

      <% if flash[:alert] %>
        <div class="error-messages">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <% if @listing.errors.any? %>
        <div class="error-messages">
          <ul>
            <% @listing.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: @listing,
                    url: sell_path,
                    local: true,
                    multipart: true,
                    data: { turbo: false },
                    class: "styled-form" do |f| %>

        <div class="form-group image-upload-group <%= 'has-error' if @listing.errors[:photos].any? %>">
          <%= f.label :photos, "Images (8 images maximum)", class: "form-label" %>
          
          <div class="upload-container">
          
            <%= f.file_field :photos, 
                             multiple: true, 
                             accept: "image/*", 
                             class: "file-input-hidden",
                             id: "photo-upload" %>
            
            <div class="preview-grid" id="preview-grid"></div>
            
            <div class="upload-area" id="upload-area">
              <i class="fas fa-cloud-upload-alt"></i>
              <p>click to upload images</p>
              <small>maximum 8 photos (uploaded <span id="photo-count">0</span>/8)</small>
            </div>
          </div>
          <% if @listing.errors[:photos].any? %>
            <span class="error-message"><%= @listing.errors[:photos].first %></span>
          <% end %>
        </div>

        <div class="form-row">
          <div class="form-group <%= 'has-error' if @listing.errors[:category].any? %>">
            <%= f.label :category, class: "form-label" %>
            <%= f.select :category, ["Electronics", "Textbooks", "Furniture", "Clothing", "Others"], 
                         { include_blank: "Select a category" },
                         class: "form-select" %>
            <% if @listing.errors[:category].any? %>
              <span class="error-message"><%= @listing.errors[:category].first %></span>
            <% end %>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group <%= 'has-error' if @listing.errors[:title].any? %>">
            <%= f.label :title, "Listing title", class: "form-label" %>
            <%= f.text_field :title, placeholder: "What are you selling?", class: "form-input", maxlength: 40 %>
            <% if @listing.errors[:title].any? %>
              <span class="error-message"><%= @listing.errors[:title].first %></span>
            <% end %>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group <%= 'has-error' if @listing.errors[:price].any? %>">
            <%= f.label :price, class: "form-label" %>
            <%= f.number_field :price, step: 1, placeholder: "$0.00", class: "form-input price-input" %>
            <% if @listing.errors[:price].any? %>
              <span class="error-message"><%= @listing.errors[:price].first %></span>
            <% end %>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group <%= 'has-error' if @listing.errors[:condition].any? %>">
            <%= f.label :condition, class: "form-label" %>
            <%= f.select :condition, ["New", "Like New", "Good", "Fair", "Poor"], {}, class: "form-select" %>
            <% if @listing.errors[:condition].any? %>
              <span class="error-message"><%= @listing.errors[:condition].first %></span>
            <% end %>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group <%= 'has-error' if @listing.errors[:location].any? %>">
            <%= f.label :location, class: "form-label" %>
            <%= f.text_field :location, placeholder: "Chung Chi College", class: "form-input" %>
            <% if @listing.errors[:location].any? %>
              <span class="error-message"><%= @listing.errors[:location].first %></span>
            <% end %>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group <%= 'has-error' if @listing.errors[:description].any? %>">
            <%= f.label :description, class: "form-label" %>
            <%= f.text_area :description, rows: 6, placeholder: "Describe your item in detail...", class: "form-input form-textarea" %>
            <% if @listing.errors[:description].any? %>
              <span class="error-message"><%= @listing.errors[:description].first %></span>
            <% end %>
          </div>
        </div>

        <div class="form-actions">
          <%= f.submit "List it!", class: "submit-btn" %>
          <%= link_to "Cancel", root_path, class: "cancel-btn" %>
        </div>

      <% end %>
    </div>
  </div>
</div>

<!--JavaScript -->
<script>

  (function() {
    let imageUploaderInitialized = false;

    function initImageUploader() {
      const fileInput = document.getElementById('photo-upload');
      const uploadArea = document.getElementById('upload-area');
      const previewGrid = document.getElementById('preview-grid');
      const photoCountSpan = document.getElementById('photo-count');


      if (!fileInput || !uploadArea || !previewGrid || !photoCountSpan) return;


      imageUploaderInitialized = false;

      if (imageUploaderInitialized) return;
      imageUploaderInitialized = true;

      let currentFiles = [];
      const MAX_PHOTOS = 8;

      fileInput.value = '';
      currentFiles = [];
      previewGrid.innerHTML = '';
      photoCountSpan.textContent = '0';

      const newFileInput = fileInput.cloneNode(true);
      fileInput.parentNode.replaceChild(newFileInput, fileInput);
      
      const newUploadArea = uploadArea.cloneNode(true);
      uploadArea.parentNode.replaceChild(newUploadArea, uploadArea);
    
      const finalFileInput = document.getElementById('photo-upload');
      const finalUploadArea = document.getElementById('upload-area');
      const finalPreviewGrid = document.getElementById('preview-grid');
      const finalPhotoCountSpan = document.getElementById('photo-count');

      function updatePhotoCount() {
        finalPhotoCountSpan.textContent = currentFiles.length;
      }

      function syncFilesToInput() {
        const dataTransfer = new DataTransfer();
        currentFiles.forEach(file => dataTransfer.items.add(file));
        finalFileInput.files = dataTransfer.files;
      }

      function renderPreviews() {
        finalPreviewGrid.innerHTML = '';

        currentFiles.forEach((file, index) => {
          const previewItem = document.createElement('div');
          previewItem.className = 'preview-item';
          previewItem.dataset.index = index;

          const reader = new FileReader();
          reader.onload = (e) => {
            previewItem.innerHTML = `
              <img src="${e.target.result}" alt="Preview ${index + 1}">
              <button type="button" class="remove-image" data-index="${index}">
                <i class="fas fa-times"></i>
              </button>
            `;
          };
          reader.readAsDataURL(file);
          finalPreviewGrid.appendChild(previewItem);
        });
      }

      function handleFiles(newFiles) {
        const validFiles = Array.from(newFiles).filter(file => file.type.startsWith('image/'));

        if (currentFiles.length + validFiles.length > MAX_PHOTOS) {
          alert(`Maximum ${MAX_PHOTOS} photos allowed`);
          return;
        }

        currentFiles = [...currentFiles, ...validFiles];
        syncFilesToInput();
        renderPreviews();
        updatePhotoCount();
      }

      function removeImage(indexToRemove) {
        currentFiles.splice(indexToRemove, 1);
        syncFilesToInput();
        renderPreviews();
        updatePhotoCount();
      }

      finalUploadArea.addEventListener('click', (e) => {
        e.preventDefault();
        finalFileInput.value = '';
        finalFileInput.click();
      });

      finalFileInput.addEventListener('change', (e) => {
        e.preventDefault();
        handleFiles(e.target.files);
      });

      finalPreviewGrid.addEventListener('click', (e) => {
        const removeBtn = e.target.closest('.remove-image');
        if (removeBtn) {
          e.stopPropagation();
          e.preventDefault();
          const index = parseInt(removeBtn.dataset.index, 10);
          removeImage(index);
        }
      });
    }


    document.addEventListener('turbo:load', function() {
      initImageUploader();
    });
    
    document.addEventListener('turbolinks:load', function() {
      initImageUploader();
    });
    
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initImageUploader);
    } else {
      initImageUploader();
    }
    
    window.addEventListener('pageshow', function(event) {
      if (event.persisted) {
        initImageUploader();
      }
    });
  })();
</script>