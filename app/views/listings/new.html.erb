<div class="app">
  <%= render "home/header" %>

  <!-- 新增物品表單 -->
  <div class="new-listing-container">
    <div class="form-card">
      <h2 class="form-title">Create a new listing</h2>

      <%= form_with model: @listing,
                    url: listings_path,
                    local: true,
                    multipart: true,
                    class: "styled-form" do |f| %>

        <!-- 更漂亮的 Image 上傳區域 -->
        <div class="form-group image-upload-group">
          <%= f.label :photos, "Images", class: "form-label" %>
          <div class="upload-area" id="upload-area">
            <%= f.file_field :photos, 
                             multiple: true, 
                             accept: "image/*", 
                             class: "file-input-hidden" %>
            <div class="upload-placeholder">
              <i class="fas fa-cloud-upload-alt"></i>
              <p>Click to upload or drag & drop photos here</p>
              <small>10 photos at most</small>
            </div>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <%= f.label :category, class: "form-label" %>
            <%= f.select :category, ["Electronics", "Textbooks", "Furniture", "Clothing", "Others"], 
                         { include_blank: "Select a category" },
                         class: "form-select" %>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <%= f.label :title, "Listing title", class: "form-label" %>
            <%= f.text_field :title, placeholder: "What are you selling?", class: "form-input" %>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <%= f.label :price, class: "form-label" %>
            <div class="price-input-group">
              <span class="currency-symbol">$</span>
              <%= f.number_field :price, step: 0.01, placeholder: "0.00", class: "form-input price-input" %>
            </div>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <%= f.label :condition, class: "form-label" %>
            <%= f.select :condition, ["New", "Like New", "Good", "Fair", "Poor"], {}, class: "form-select" %>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <%= f.label :location, class: "form-label" %>
            <%= f.text_field :location, placeholder: "e.g. CUHK, Sha Tin", class: "form-input" %>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <%= f.label :description, class: "form-label" %>
            <%= f.text_area :description, rows: 6, placeholder: "Describe your item in detail...", class: "form-input form-textarea" %>
          </div>
        </div>

        <div class="form-actions">
          <%= f.submit "List it!", class: "submit-btn" %>
        </div>

      <% end %>
    </div>
  </div>
</div>