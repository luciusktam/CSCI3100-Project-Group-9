<div class="app">
  <header class="navbar">
    <div class="navbar-left">
      <%= link_to community_path, class: "nav-community-btn#{' active' if request.path.start_with?('/community')}", aria: { label: "Community" } do %>
        <i class="fas fa-users"></i>
      <% end %>
      <%= link_to root_path, class: "logo" do %>
        CUMarket
      <% end %>
    </div>

    <div class="nav-links">
      <% if user_signed_in? && current_user.admin? %>
        <%= link_to admin_dashboard_path, class: "admin-nav-link#{' active' if request.path.start_with?('/admin')}" do %>
          <i class="fas fa-shield-alt"></i> Admin
        <% end %>
      <% end %>
    </div>

    <div class="right-corner">
      <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle dark mode" aria-pressed="false">
        <i class="fas fa-moon"></i>
        <span>Dark</span>
      </button>

      <% if user_signed_in? %>
        <%= link_to profile_path, class: "session-badge" do %>
          <i class="fas fa-user-check"></i>
          <%= current_user.username %>
          <% if current_user.admin? %>
            <strong>Admin</strong>
          <% end %>
        <% end %>

        <%= link_to chat_path, class: "nav-chat-btn", "aria-label": "Chat" do %>
          <i class="fas fa-comment-dots"></i>
          <span id="chatNavBadge" class="nav-badge" style="display: none;">0</span>
        <% end %>
      <% else %>
        <%= link_to login_path, class: "login-btn" do %>
          <i class="fas fa-sign-in-alt"></i> Login
        <% end %>
      <% end %>
    </div>
  </header>

  <%= render "listings/search_filters" %>

  <div class="section-header">
    <h2></h2>
    <div class="section-actions">
      <% if user_signed_in? %>
        <%= link_to "Your Listings", listings_path(user_id: current_user.id), class: "community-btn secondary" %>
        <%= link_to "Post Items", sell_path, class: "community-btn primary" %>
      <% end %>
    </div>
  </div>

  <% if @listings.present? && @listings.any? %>
    <div class="listings-grid">
      <% @listings.each do |listing| %>
        <%= render partial: "listings/listing_card", locals: { listing: listing } %>
      <% end %>
    </div>

    <% if @listings.total_pages > 1 %>
      <div class="pagination">
        <%= paginate @listings %>
      </div>
    <% end %>
  <% else %>
    <div class="no-listings">
      <i class="fas fa-box-open"></i>
      <h3>No listings yet</h3>
      <p>Be the first to list an item!</p>
    </div>
  <% end %>
</div>
