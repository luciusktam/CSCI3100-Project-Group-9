<!DOCTYPE html>
<html>
  <head>
    <meta content="text/html; charset=UTF-8" http-equiv="Content-Type" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  </head>
  <body style="margin: 0; padding: 0; background-color: #f6f4fb; font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, Roboto, Helvetica, Arial, sans-serif;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background-color: #f6f4fb;">
      <tr>
        <td align="center" style="padding: 40px 20px;">
          <!-- Card Container -->
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width: 520px; background-color: #ffffff; border-radius: 16px; box-shadow: 0 4px 24px rgba(91, 44, 131, 0.12); overflow: hidden;">
            <!-- Header with Brand -->
            <tr>
              <td style="background: linear-gradient(135deg, #5b2c83 0%, #4b236c 100%); padding: 36px 32px; text-align: center;">
                <!-- CUMarket Icon (Shopping Bag) -->
                <div style="display: inline-block; margin-bottom: 16px;">
                  <svg width="56" height="56" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect width="56" height="56" rx="14" fill="rgba(255,255,255,0.15)"/>
                    <path d="M18 22C18 19.7909 19.7909 18 22 18H34C36.2091 18 38 19.7909 38 22V34C38 36.2091 36.2091 38 34 38H22C19.7909 38 18 36.2091 18 34V22Z" fill="#F6F4FB"/>
                    <path d="M22 28C22 26.8954 22.8954 26 24 26H32C33.1046 26 34 26.8954 34 28C34 29.1046 33.1046 30 32 30H24C22.8954 30 22 29.1046 22 28Z" fill="#5b2c83"/>
                    <circle cx="28" cy="33" r="1.5" fill="#B4975A"/>
                    <path d="M24 22V18C24 16.8954 24.8954 16 26 16H30C31.1046 16 32 16.8954 32 18V22" stroke="#B4975A" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                </div>
                <h1 style="margin: 0; font-size: 26px; font-weight: 700; color: #ffffff; letter-spacing: -0.5px;">
                  CU Market
                </h1>
                <p style="margin: 8px 0 0; font-size: 14px; color: rgba(255,255,255,0.75);">
                  CUHK Campus Marketplace
                </p>
              </td>
            </tr>

            <!-- Body Content -->
            <tr>
              <td style="padding: 36px 32px;">
                <!-- Greeting -->
                <h2 style="margin: 0 0 8px; font-size: 22px; font-weight: 600; color: #221b2b; line-height: 1.3;">
                  Hey <%= @user.username %>, welcome aboard! 👋
                </h2>
                <p style="margin: 0 0 24px; font-size: 15px; color: #6a6077; line-height: 1.6;">
                  Thank you for joining CUMarket. To get started, please verify your CUHK email address by clicking the button below.
                </p>

                <!-- CTA Button -->
                <div style="text-align: center; margin: 32px 0;">
                  <a href="<%= @verify_url %>"
                     style="display: inline-block; background: linear-gradient(135deg, #5b2c83 0%, #7c4aa8 100%); color: #ffffff; text-decoration: none; padding: 16px 36px; border-radius: 10px; font-size: 16px; font-weight: 600; box-shadow: 0 4px 16px rgba(91, 44, 131, 0.35);">
                    Verify Email Address
                  </a>
                </div>

                <!-- Divider -->
                <div style="display: flex; align-items: center; margin: 28px 0;">
                  <div style="flex: 1; height: 1px; background: #e2e8f0;"></div>
                  <span style="padding: 0 16px; font-size: 13px; color: #6a6077;">or copy this link into your browser</span>
                  <div style="flex: 1; height: 1px; background: #e2e8f0;"></div>
                </div>

                <!-- Fallback Link -->
                <div style="background: #f6f4fb; border-radius: 8px; padding: 16px; margin-bottom: 24px;">
                  <p style="margin: 0; font-size: 13px; color: #6a6077; word-break: break-all; font-family: 'Courier New', Courier, monospace;">
                    <%= @verify_url %>
                  </p>
                </div>

                <!-- Note -->
                <div style="background: #ede9fe; border-left: 4px solid #5b2c83; border-radius: 0 8px 8px 0; padding: 14px 16px; margin-bottom: 24px;">
                  <p style="margin: 0; font-size: 13px; color: #4a3d61; line-height: 1.5;">
                    <strong>Tip:</strong> This verification link expires in <strong>24 hours</strong>.
                  </p>
                </div>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td style="background: #f6f4fb; padding: 24px 32px; text-align: center; border-top: 1px solid #e2e8f0;">
                <p style="margin: 0 0 8px; font-size: 13px; color: #6a6077;">
                  If you didn't create a CUMarket account, you can safely ignore this email.
                </p>
                <p style="margin: 0; font-size: 12px; color: #a0aec0;">
                  © <%= Time.current.year %> CU Market · CUHK Campus Marketplace
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
