<!DOCTYPE html>
<html>
  <head>
    <meta content="text/html; charset=UTF-8" http-equiv="Content-Type" />
  </head>
  <body style="font-family: Arial, sans-serif; color: #333; max-width: 600px; margin: 0 auto; padding: 20px;">
    <h2 style="color: #0057a8;">Welcome to CUMarket, <%= @user.username %>!</h2>

    <p>Thank you for registering. Please verify your CUHK email address to activate your account.</p>

    <p style="text-align: center; margin: 30px 0;">
      <a href="<%= @verify_url %>"
         style="background: #0057a8; color: #fff; padding: 12px 28px; text-decoration: none; border-radius: 4px; font-size: 16px;">
        Verify my email address
      </a>
    </p>

    <p style="font-size: 13px; color: #555;">Or copy this link into your browser:</p>
    <p style="font-size: 13px; word-break: break-all;"><%= @verify_url %></p>

    <hr style="border: none; border-top: 1px solid #eee; margin: 30px 0;" />
    <p style="font-size: 12px; color: #aaa;">
      If you did not create a CUMarket account, you can safely ignore this email.
    </p>
  </body>
</html>
