<div class="app auth-page">
  <header class="navbar auth-navbar">
    <%= link_to root_path, class: "logo" do %>
      CUMarket
    <% end %>
    <div class="right-corner">
      <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle dark mode">
        <i class="fas fa-moon"></i>
        <span>Dark</span>
      </button>
    </div>
  </header>

  <section class="auth-layout auth-layout-single">
    <div class="auth-card-grid">
      <section class="auth-card">
        <h2>Forgot password</h2>

        <%= form_with url: forgot_password_path, method: :post, local: true, class: "auth-form" do |form| %>
          <div class="field-group">
            <%= form.label :email, "CUHK Email" %>
            <%= form.email_field :email, name: :email, placeholder: "sid@link.cuhk.edu.hk", required: true %>
          </div>

          <%= form.submit "Send reset link", class: "search-btn auth-submit" %>
        <% end %>

        <p class="auth-switch"><%= link_to "Back to login", login_path, class: "auth-inline-link" %></p>
      </section>
    </div>
  </section>
</div>